{
  "description": "Blocks code file edits during research and plan phases",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/phase-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
